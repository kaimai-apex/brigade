# ConnectPro / Brigade Platform Environment Variables

# Infrastructure — use Supabase Postgres if no local Docker:
# Supabase → Project Settings → Database → Connection string
#
# For Vercel/serverless, do NOT use the direct host db.[PROJECT].supabase.co (IPv6-only).
# Use the Transaction pooler URI from the dashboard, or set the legacy direct URI and
# Brigade will auto-rewrite it to the pooler. Example pooler format:
# DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# SUPABASE_REGION=us-east-1
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
MONGO_URL=mongodb://localhost:27017/connectpro
OPENSEARCH_URL=http://localhost:9200

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d
# Use connectpro_auth on Supabase (auth schema is reserved). Use auth for local Docker Postgres.
AUTH_SCHEMA=connectpro_auth

# API Gateway — use GATEWAY_PORT, not PORT (PORT breaks dev:stack)
GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:3002
USER_SERVICE_URL=http://localhost:3003
CONNECTION_SERVICE_URL=http://localhost:3004
POST_SERVICE_URL=http://localhost:3005
FEED_SERVICE_URL=http://localhost:3006
MESSAGING_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008
SEARCH_SERVICE_URL=http://localhost:3009
JOB_SERVICE_URL=http://localhost:3010
COMPANY_SERVICE_URL=http://localhost:3011
MEDIA_SERVICE_URL=http://localhost:3012
ANALYTICS_SERVICE_URL=http://localhost:3013
RECOMMENDATION_SERVICE_URL=http://localhost:3014

# Web App (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# Vercel server-only (Settings → Environment Variables — NOT prefixed with NEXT_PUBLIC_)
# Required for email/password auth without a deployed microservice stack:
# DATABASE_URL — use Supabase *Transaction pooler* URI (port 6543), NOT db.[PROJECT].supabase.co
# JWT_SECRET=generate-a-long-random-string
# AUTH_SCHEMA=connectpro_auth
# SUPABASE_REGION=us-west-2   # only if auto-rewrite from legacy db.* URL picks wrong region
# Or set discrete vars if your password contains @ or # (avoids URL parsing issues):
# SUPABASE_DB_HOST=aws-0-us-west-2.pooler.supabase.com
# SUPABASE_DB_USER=postgres.tldovunmovsbxqcpxwvs
# SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_DB_PORT=6543
